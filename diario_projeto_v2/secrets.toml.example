# ──────────────────────────────────────────────────────────────────────────────
# .streamlit/secrets.toml
# NÃO suba este arquivo para o GitHub! (já está no .gitignore)
#
# Para uso LOCAL: renomeie este arquivo para secrets.toml
# Para Streamlit Cloud: cole o conteúdo em App Settings → Secrets
# ──────────────────────────────────────────────────────────────────────────────

# Banco de dados PostgreSQL (Supabase)
# Copie de: Supabase → Settings → Database → Connection string → URI
DATABASE_URL = "postgresql://postgres:SUA_SENHA@db.XXXXXX.supabase.co:5432/postgres"

# Usuários do sistema
# Gere o hash com:
#   python -c "import hashlib; print(hashlib.sha256('SUA_SENHA'.encode()).hexdigest())"
#
# Padrões abaixo:  admin → admin123  |  professor → prof123
[usuarios]
admin     = "240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9"
professor = "00624b02e1f9b996a3278f559d5d55313552ad2c0bafc82adfd975c12df61eaf"

[nomes]
admin     = "Administrador"
professor = "Professora Ana"

[perfis]
admin     = "admin"
professor = "professor"
